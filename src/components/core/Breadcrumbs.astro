---
interface Props {
	lists: { href: string; text: string }[];
}

const { lists = [] } = Astro.props;
---

{
	// lists が空の場合は何も表示しない
	() => {
		if (lists.length === 0) {
			return;
		} else {
			return (
				<nav class="cBreadcrumb" aria-label="パンくずリスト">
					<ol
						class="cBreadcrumb__list"
						itemscope
						itemtype="https://schema.org/BreadcrumbList"
					>
						<li
							class="cBreadcrumb__item"
							itemprop="itemListElement"
							itemscope
							itemtype="https://schema.org/ListItem"
						>
							<a
								href="/"
								class="cBreadcrumb__item_link cHoverColor"
								itemprop="item"
							>
								<span
									class="cBreadcrumb__item_text"
									itemprop="name"
								>
									ホーム
								</span>
							</a>

							<meta itemprop="position" content="1" />
						</li>
						{lists.map((list, index) => (
							<li
								class="cBreadcrumb__item"
								itemprop="itemListElement"
								itemscope
								itemtype="https://schema.org/ListItem"
							>
								{lists.length - 1 !== index ? (
									<a
										href={`/${list.href}/`}
										class="cBreadcrumb__item_link cHoverColor"
										itemprop="item"
									>
										<span
											class="cBreadcrumb__item_text"
											itemprop="name"
											set:html={list.text}
										/>

										<meta
											itemprop="position"
											content={`${index + 2}`}
										/>
									</a>
								) : (
									<div
										class="cBreadcrumb__item_current"
										itemprop="item"
									>
										<span
											class="cBreadcrumb__item_text"
											itemprop="name"
											set:html={list.text}
										/>

										<meta
											itemprop="position"
											content={`${index + 2}`}
										/>
									</div>
								)}
							</li>
						))}
					</ol>
				</nav>
			);
		}
	}
}
