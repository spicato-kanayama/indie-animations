{
	"extends": "astro/tsconfigs/base",
	"compilerOptions": {
		"paths": {
			"@/*": ["./src/*"],
			"@components/*": ["./src/components/*"],
			"@layouts/*": ["./src/layouts/*"],
			"@images/*": ["./src/assets/images/*"],
			"@js/*": ["./src/assets/js/*"],
			"@scss/*": ["./src/assets/scss/*"]
		}
	}
}
